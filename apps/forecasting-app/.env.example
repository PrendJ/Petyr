# Petyr Forecasting App
# In Docker root compose, the DB hostname is postgres.
DATABASE_URL=postgresql://unguess:unguess_password@postgres:5432/unguess_redash?schema=public

# Future AI integration via OpenRouter. Never hardcode the real key.
# /petyr-admin uses OPENROUTER_DEFAULT_MODEL when no database setting exists.
OPENROUTER_API_KEY=replace_me
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Petyr Intelligence external-signal MVP. Provider keys stay server-side only.
EXA_API_KEY=replace_me
INTELLIGENCE_ENABLED=false
INTELLIGENCE_MAX_COMPANIES_PER_RUN=10
INTELLIGENCE_MAX_RESULTS_PER_COMPANY=5
INTELLIGENCE_SEARCH_RECENCY_DAYS=30
INTELLIGENCE_DAILY_BUDGET_REQUESTS=100
INTELLIGENCE_WORKER_ENABLED=false
INTELLIGENCE_SCAN_DAILY_TIME=03:00
INTELLIGENCE_SCAN_TIMEZONE=Europe/Rome

PETYR_APP_NAME=Petyr
PETYR_DEFAULT_YEAR=current
PETYR_TIMEZONE=Europe/Rome
PETYR_AI_FORECAST_DAILY_TIME=02:00
PETYR_AI_FORECAST_DELAY_MS=3000

# Petyr Access Layer integration.
# In local development, Petyr auth defaults to disabled unless this is set to access-layer.
# In production, use PETYR_AUTH_MODE=access-layer and configure real Coolify secrets.
PETYR_AUTH_MODE=disabled
ACCESS_LAYER_PUBLIC_BASE_URL=https://access-layer.draftapps.it
ACCESS_LAYER_INTERNAL_BASE_URL=https://access-layer.draftapps.it
ACCESS_LAYER_CALLBACK_URL=https://petyr.draftapps.it/auth/callback
ACCESS_LAYER_TOOL_SLUG=petyr
ACCESS_LAYER_CLIENT_ID=replace_with_petyr_tool_client_id
ACCESS_LAYER_CLIENT_SECRET=replace_with_petyr_tool_client_secret
PETYR_SESSION_SECRET=replace_with_long_random_session_secret

# Optional verbose server-side Petyr/Redash performance instrumentation.
PETYR_PERF_LOGS=false
