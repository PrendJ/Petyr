generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum ForecastType {
  previous_month
  ongoing
}

enum ForecastMonthlyStatus {
  draft
  saved
  locked
}

enum ForecastAnnualStatus {
  draft
  consolidated
}

enum ForecastAnnualSnapshotType {
  // Deprecated: Initial Forecast now comes from Annual Forecast Entry.
  initial
}

enum ForecastAnnualSnapshotSource {
  // Deprecated: legacy Initial Forecast snapshot import/consolidation sources.
  manual_excel_2026
  year_end_consolidation
  admin
}

enum ManagementObjectiveScopeType {
  branch
  business_unit
}

enum IntelligenceRunStatus {
  pending
  running
  succeeded
  partial
  failed
  skipped_budget
  skipped_disabled
  skipped_lock
}

enum IntelligenceInsightType {
  opportunity
  reactivation
  caution
  risk
  monitor
  no_action
}

enum IntelligenceUrgency {
  high
  medium
  low
}

enum IntelligenceFeedbackUsefulness {
  useful
  not_useful
  unclear
}

enum IntelligenceFeedbackAccuracy {
  accurate
  inaccurate
  unclear
}

// Read model for the tables owned by apps/redash-ingestor.
// Forecasting must not call Redash directly: it reads these snapshots from PostgreSQL.
model RedashSource {
  id             String           @id @default(uuid())
  key            String           @unique
  name           String
  redashQueryId  Int
  apiKey         String?
  parameters     Json             @default("{}")
  maxAgeSeconds  Int              @default(0)
  enabled        Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  runs           RedashSyncRun[]
  snapshots      RedashSnapshot[]

  @@index([enabled])
}

model RedashSyncRun {
  id             String           @id @default(uuid())
  sourceId       String
  source         RedashSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status         SyncStatus       @default(RUNNING)
  triggeredBy    String           @default("worker")
  startedAt      DateTime         @default(now())
  finishedAt     DateTime?
  errorMessage   String?
  rowsCount      Int?
  queryResultId  Int?
  createdAt      DateTime         @default(now())

  snapshot       RedashSnapshot?

  @@index([sourceId, startedAt])
  @@index([status])
}

model RedashSyncLock {
  key         String   @id
  owner       String
  acquiredAt  DateTime @default(now())
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model RedashSnapshot {
  id             String           @id @default(uuid())
  sourceId       String
  source         RedashSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runId          String           @unique
  run            RedashSyncRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  fetchedAt      DateTime         @default(now())
  queryResultId  Int?
  rowsCount      Int?
  payloadHash    String
  payload        Json
  createdAt      DateTime         @default(now())

  @@index([sourceId, fetchedAt])
  @@index([payloadHash])
}

model RedashColumnMapping {
  id                String   @id @default(uuid())
  sourceKey         String   @map("source_key")
  redashColumnName  String   @map("redash_column_name")
  dbColumnName      String   @map("db_column_name")
  position          Int
  detectedType      String   @map("detected_type")
  lastSeenAt        DateTime @map("last_seen_at")

  @@unique([sourceKey, redashColumnName], map: "redash_column_mapping_source_column_key")
  @@index([sourceKey], map: "redash_column_mapping_source_key_idx")
  @@map("redash_column_mapping")
}

model ForecastMonthly {
  id              String                @id @default(cuid())
  companyName     String                @map("company_name")
  csmName         String                @map("csm_name")
  businessUnit    String                @map("business_unit")
  year            Int
  month           Int
  forecastType    ForecastType          @map("forecast_type")
  value           Decimal               @db.Decimal(14, 2)
  aiForecastValue Decimal?              @map("ai_forecast_value") @db.Decimal(14, 2)
  status          ForecastMonthlyStatus @default(draft)
  createdBy       String                @map("created_by")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedBy       String?               @map("updated_by")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@unique([companyName, businessUnit, year, month, forecastType], map: "forecast_monthly_company_bu_year_month_type_key")
  @@index([companyName, year, month], map: "forecast_monthly_company_year_month_idx")
  @@index([csmName, year, month], map: "forecast_monthly_csm_year_month_idx")
  @@index([status], map: "forecast_monthly_status_idx")
  @@map("forecast_monthly")
}

model ForecastAnnual {
  id              String               @id @default(cuid())
  companyName     String               @map("company_name")
  csmName         String               @map("csm_name")
  businessUnit    String               @map("business_unit")
  year            Int
  value           Decimal              @db.Decimal(14, 2)
  initialForecast Decimal?             @map("initial_forecast") @db.Decimal(14, 2)
  aiForecastValue Decimal?             @map("ai_forecast_value") @db.Decimal(14, 2)
  valueSource     String               @default("manual") @map("value_source")
  status          ForecastAnnualStatus @default(draft)
  note            String?              @db.Text
  createdBy       String               @map("created_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedBy       String?              @map("updated_by")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  consolidatedBy  String?              @map("consolidated_by")
  consolidatedAt  DateTime?            @map("consolidated_at")

  @@unique([companyName, businessUnit, year], map: "forecast_annual_company_bu_year_key")
  @@index([companyName, year], map: "forecast_annual_company_year_idx")
  @@index([csmName, year], map: "forecast_annual_csm_year_idx")
  @@index([valueSource], map: "forecast_annual_value_source_idx")
  @@index([status], map: "forecast_annual_status_idx")
  @@map("forecast_annual")
}

model ForecastAnnualEntry {
  id                String   @id @default(cuid())
  companyName       String   @map("company_name")
  csmName           String   @map("csm_name")
  year              Int
  initialForecast   Decimal? @map("initial_forecast") @db.Decimal(14, 2)
  ongoingConfidence String?  @map("ongoing_confidence")
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedBy         String?  @map("updated_by")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([companyName, year], map: "forecast_annual_entry_company_year_key")
  @@index([csmName, year], map: "forecast_annual_entry_csm_year_idx")
  @@index([ongoingConfidence], map: "forecast_annual_entry_confidence_idx")
  @@map("forecast_annual_entry")
}

/// Deprecated: legacy Initial Forecast snapshot storage. Product read paths now use
/// ForecastAnnualEntry.initialForecast and ForecastAnnual.initialForecast.
model ForecastAnnualSnapshot {
  id           String                         @id @default(cuid())
  companyName  String                         @map("company_name")
  csmName      String                         @map("csm_name")
  businessUnit String                         @map("business_unit")
  year         Int
  snapshotType ForecastAnnualSnapshotType     @default(initial) @map("snapshot_type")
  value        Decimal                        @db.Decimal(14, 2)
  source       ForecastAnnualSnapshotSource
  note         String?                        @db.Text
  createdBy    String                         @map("created_by")
  createdAt    DateTime                       @default(now()) @map("created_at")
  lockedAt     DateTime?                      @map("locked_at")
  changeLogs   ForecastAnnualSnapshotChangeLog[]

  @@unique([companyName, businessUnit, year, snapshotType], map: "forecast_annual_snapshot_company_bu_year_type_key")
  @@index([companyName, year], map: "forecast_annual_snapshot_company_year_idx")
  @@index([csmName, year], map: "forecast_annual_snapshot_csm_year_idx")
  @@index([snapshotType, year], map: "forecast_annual_snapshot_type_year_idx")
  @@index([source], map: "forecast_annual_snapshot_source_idx")
  @@index([lockedAt], map: "forecast_annual_snapshot_locked_at_idx")
  @@map("forecast_annual_snapshot")
}

/// Deprecated: audit log for legacy Initial Forecast snapshots.
model ForecastAnnualSnapshotChangeLog {
  id             String                       @id @default(cuid())
  snapshotId     String                       @map("snapshot_id")
  snapshot       ForecastAnnualSnapshot       @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  companyName    String                       @map("company_name")
  csmName        String                       @map("csm_name")
  businessUnit   String                       @map("business_unit")
  year           Int
  snapshotType   ForecastAnnualSnapshotType   @map("snapshot_type")
  previousValue  Decimal?                     @map("previous_value") @db.Decimal(14, 2)
  newValue       Decimal                      @map("new_value") @db.Decimal(14, 2)
  previousSource ForecastAnnualSnapshotSource? @map("previous_source")
  newSource      ForecastAnnualSnapshotSource  @map("new_source")
  note           String?                      @db.Text
  changedBy      String                       @map("changed_by")
  changedAt      DateTime                     @default(now()) @map("changed_at")

  @@index([snapshotId], map: "forecast_annual_snapshot_change_log_snapshot_idx")
  @@index([companyName, businessUnit, year], map: "forecast_annual_snapshot_change_log_company_bu_year_idx")
  @@index([snapshotType, year], map: "forecast_annual_snapshot_change_log_type_year_idx")
  @@index([changedAt], map: "forecast_annual_snapshot_change_log_changed_at_idx")
  @@map("forecast_annual_snapshot_change_log")
}

model ForecastSaveSession {
  id                  String              @id @default(cuid())
  companyName         String              @map("company_name")
  csmName             String              @map("csm_name")
  source              String
  year                Int
  month               Int
  forecastType        ForecastType        @map("forecast_type")
  note                String?             @db.Text
  companyActiveStatus Boolean             @map("company_active_status")
  createdBy           String              @map("created_by")
  createdAt           DateTime            @default(now()) @map("created_at")
  changeLogs          ForecastChangeLog[]

  @@index([companyName, year, month], map: "forecast_save_session_company_year_month_idx")
  @@index([csmName, year, month], map: "forecast_save_session_csm_year_month_idx")
  @@index([createdAt], map: "forecast_save_session_created_at_idx")
  @@map("forecast_save_session")
}

model ForecastChangeLog {
  id                    String              @id @default(cuid())
  saveSessionId         String              @map("save_session_id")
  saveSession           ForecastSaveSession @relation(fields: [saveSessionId], references: [id], onDelete: Cascade)
  companyName           String              @map("company_name")
  businessUnit          String              @map("business_unit")
  fieldName             String              @map("field_name")
  previousValue         String?             @map("previous_value") @db.Text
  newValue              String?             @map("new_value") @db.Text
  aiForecastValueAtSave Decimal?            @map("ai_forecast_value_at_save") @db.Decimal(14, 2)
  createdBy             String              @map("created_by")
  createdAt             DateTime            @default(now()) @map("created_at")

  @@index([saveSessionId], map: "forecast_change_log_save_session_idx")
  @@index([companyName, businessUnit], map: "forecast_change_log_company_bu_idx")
  @@index([createdAt], map: "forecast_change_log_created_at_idx")
  @@map("forecast_change_log")
}

model CompanyForecastStatus {
  id          String   @id @default(cuid())
  companyName String   @unique(map: "company_forecast_status_company_key") @map("company_name")
  isActive    Boolean  @default(true) @map("is_active")
  reason      String?  @db.Text
  updatedBy   String   @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("company_forecast_status")
}

model AppSetting {
  settingKey   String   @id @map("setting_key")
  settingValue String   @map("setting_value") @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("app_setting")
}

model PetyrPerformanceMeasurement {
  id         String   @id @default(cuid())
  service    String
  operation  String
  status     String   @default("measured")
  durationMs Int?     @map("duration_ms")
  rowCount   Int?     @map("row_count")
  metadata   Json     @default("{}")
  measuredAt DateTime @default(now()) @map("measured_at")

  @@index([service, operation, measuredAt], map: "petyr_performance_measurement_service_op_time_idx")
  @@index([measuredAt], map: "petyr_performance_measurement_measured_at_idx")
  @@map("petyr_performance_measurement")
}

model AiForecastCache {
  id                    String   @id @default(cuid())
  companyName           String   @map("company_name")
  businessUnit          String   @map("business_unit")
  year                  Int
  month                 Int
  forecastValue         Decimal  @map("forecast_value") @db.Decimal(14, 2)
  confidenceScore       Decimal? @map("confidence_score") @db.Decimal(5, 4)
  modelVersion          String   @map("model_version")
  explanation           String?  @db.Text
  generatedAt           DateTime @default(now()) @map("generated_at")
  provider              String?  @default("openrouter")
  providerModel         String?  @map("model")
  promptVersion         String?  @map("prompt_version")
  inputHash             String?  @map("input_hash")
  requestPayloadSummary Json?    @map("request_payload_summary")
  validatedOutput       Json?    @map("validated_output")
  status                String   @default("success")
  errorMessage          String?  @map("error_message") @db.Text
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([companyName, businessUnit, year, month, modelVersion], map: "ai_forecast_cache_company_bu_year_month_model_key")
  @@index([companyName, year, month], map: "ai_forecast_cache_company_year_month_idx")
  @@index([companyName, year, promptVersion, inputHash], map: "ai_forecast_cache_company_year_prompt_hash_idx")
  @@index([status], map: "ai_forecast_cache_status_idx")
  @@index([generatedAt], map: "ai_forecast_cache_generated_at_idx")
  @@map("ai_forecast_cache")
}

model ManagementObjective {
  id          String                         @id @default(cuid())
  scopeType   ManagementObjectiveScopeType   @map("scope_type")
  scopeKey    String                         @map("scope_key")
  year        Int
  value       Decimal                        @db.Decimal(14, 2)
  note        String?                        @db.Text
  createdBy   String                         @map("created_by")
  createdAt   DateTime                       @default(now()) @map("created_at")
  updatedBy   String?                        @map("updated_by")
  updatedAt   DateTime                       @updatedAt @map("updated_at")
  changeLogs  ManagementObjectiveChangeLog[]

  @@unique([scopeType, scopeKey, year], map: "management_objective_scope_key_year_key")
  @@index([scopeType, year], map: "management_objective_scope_year_idx")
  @@index([updatedAt], map: "management_objective_updated_at_idx")
  @@map("management_objective")
}

model ManagementObjectiveChangeLog {
  id             String                       @id @default(cuid())
  objectiveId    String                       @map("objective_id")
  objective      ManagementObjective          @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  scopeType      ManagementObjectiveScopeType @map("scope_type")
  scopeKey       String                       @map("scope_key")
  year           Int
  previousValue  Decimal?                     @map("previous_value") @db.Decimal(14, 2)
  newValue       Decimal                      @map("new_value") @db.Decimal(14, 2)
  note           String?                      @db.Text
  updatedBy      String                       @map("updated_by")
  updatedAt      DateTime                     @default(now()) @map("updated_at")

  @@index([objectiveId], map: "management_objective_change_log_objective_idx")
  @@index([scopeType, scopeKey, year], map: "management_objective_change_log_scope_key_year_idx")
  @@index([updatedAt], map: "management_objective_change_log_updated_at_idx")
  @@map("management_objective_change_log")
}

model CompanyIntelligenceRun {
  id                     String                @id @default(cuid())
  runScope               String                @default("batch") @map("run_scope")
  companyName            String?               @map("company_name")
  csmName                String?               @map("csm_name")
  status                 IntelligenceRunStatus @default(pending)
  dryRun                 Boolean               @default(true) @map("dry_run")
  startedAt              DateTime              @default(now()) @map("started_at")
  finishedAt             DateTime?             @map("finished_at")
  selectedReason         String?               @map("selected_reason") @db.Text
  selectedCompaniesCount Int                   @default(0) @map("selected_companies_count")
  exaRequestsUsed        Int                   @default(0) @map("exa_requests_used")
  exaResultsReceived     Int                   @default(0) @map("exa_results_received")
  openrouterRequestsUsed Int                   @default(0) @map("openrouter_requests_used")
  budgetPolicy           Json                  @default("{}") @map("budget_policy_json")
  errorMessage           String?               @map("error_message") @db.Text
  createdBy              String                @default("system") @map("created_by")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  rawResults             CompanySignalRawResult[]
  insights               CompanyIntelligenceInsight[]
  providerRequests       CompanyIntelligenceProviderRequestLog[]

  @@index([status, startedAt], map: "company_intelligence_run_status_started_idx")
  @@index([companyName, startedAt], map: "company_intelligence_run_company_started_idx")
  @@map("company_intelligence_run")
}

model CompanySignalRawResult {
  id               String                 @id @default(cuid())
  runId            String                 @map("run_id")
  run              CompanyIntelligenceRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  signalItemId     String?                @map("signal_item_id")
  signalItem       CompanySignalItem?     @relation(fields: [signalItemId], references: [id], onDelete: SetNull)
  companyName      String                 @map("company_name")
  provider         String                 @default("exa")
  providerResultId String?                @map("provider_result_id")
  queryText        String                 @map("query_text") @db.Text
  url              String                 @db.Text
  title            String?
  publishedAt      DateTime?              @map("published_at")
  authorOrSource   String?                @map("author_or_source")
  snippet          String?                @db.Text
  rawResult        Json                   @default("{}") @map("raw_result_json")
  contentHash      String                 @map("content_hash")
  fetchedAt        DateTime               @default(now()) @map("fetched_at")

  @@index([runId], map: "company_signal_raw_result_run_idx")
  @@index([companyName, fetchedAt], map: "company_signal_raw_result_company_fetched_idx")
  @@index([contentHash], map: "company_signal_raw_result_content_hash_idx")
  @@map("company_signal_raw_result")
}

model CompanySignalItem {
  id                    String                 @id @default(cuid())
  companyName           String                 @map("company_name")
  canonicalUrl          String                 @map("canonical_url") @db.Text
  normalizedTitle       String?                @map("normalized_title")
  sourceDomain          String?                @map("source_domain")
  publishedAt           DateTime?              @map("published_at")
  eventSignature        String                 @map("event_signature")
  contentHash           String                 @map("content_hash")
  firstSeenAt           DateTime               @default(now()) @map("first_seen_at")
  lastSeenAt            DateTime               @default(now()) @map("last_seen_at")
  duplicateCount        Int                    @default(1) @map("duplicate_count")
  relevanceStatus       String                 @default("pending") @map("relevance_status")
  companyRelevanceScore Decimal?               @map("company_relevance_score") @db.Decimal(5, 4)
  status                String                 @default("active")

  rawResults            CompanySignalRawResult[]
  classifications       CompanySignalBusinessUnitClassification[]
  insightSources        CompanyIntelligenceInsightSource[]

  @@unique([companyName, contentHash], map: "company_signal_item_company_hash_key")
  @@index([companyName, lastSeenAt], map: "company_signal_item_company_last_seen_idx")
  @@index([eventSignature], map: "company_signal_item_event_signature_idx")
  @@map("company_signal_item")
}

model CompanySignalBusinessUnitClassification {
  id                   String            @id @default(cuid())
  signalItemId         String            @map("signal_item_id")
  signalItem           CompanySignalItem @relation(fields: [signalItemId], references: [id], onDelete: Cascade)
  businessUnit         String            @map("business_unit")
  relevanceScore       Decimal?          @map("relevance_score") @db.Decimal(5, 4)
  rationale            String?           @db.Text
  classifiedByProvider String            @default("local") @map("classified_by_provider")
  model                String?
  promptVersion        String?           @map("prompt_version")
  classifiedAt         DateTime          @default(now()) @map("classified_at")

  @@unique([signalItemId, businessUnit], map: "company_signal_bu_classification_item_bu_key")
  @@index([businessUnit], map: "company_signal_bu_classification_bu_idx")
  @@map("company_signal_business_unit_classification")
}

model CompanyIntelligenceInsight {
  id             String                    @id @default(cuid())
  companyName    String                    @map("company_name")
  companyId      String                    @map("company_id")
  csmName        String?                   @map("csm_name")
  runId          String?                   @map("run_id")
  run            CompanyIntelligenceRun?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  businessUnit   String                    @map("business_unit")
  insightType    IntelligenceInsightType   @map("insight_type")
  title          String
  summary        String                    @db.Text
  rationale      String                    @db.Text
  suggestedAction String                   @map("suggested_action") @db.Text
  urgency        IntelligenceUrgency
  confidence     Decimal?                  @db.Decimal(5, 4)
  assumptionsOrLimits Json                 @default("[]") @map("assumptions_or_limits")
  provider       String                    @default("openrouter")
  model          String?
  promptVersion  String?                   @map("prompt_version")
  status         String                    @default("active")
  generatedAt    DateTime                  @default(now()) @map("generated_at")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  sources        CompanyIntelligenceInsightSource[]
  feedback       CompanyInsightFeedback[]

  @@index([companyName, generatedAt], map: "company_intelligence_insight_company_generated_idx")
  @@index([csmName, generatedAt], map: "company_intelligence_insight_csm_generated_idx")
  @@index([businessUnit, insightType, urgency], map: "company_intelligence_insight_bu_type_urgency_idx")
  @@map("company_intelligence_insight")
}

model CompanyIntelligenceInsightSource {
  id           String                     @id @default(cuid())
  insightId    String                     @map("insight_id")
  insight      CompanyIntelligenceInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  signalItemId String                     @map("signal_item_id")
  signalItem   CompanySignalItem          @relation(fields: [signalItemId], references: [id], onDelete: Cascade)
  createdAt    DateTime                   @default(now()) @map("created_at")

  @@unique([insightId, signalItemId], map: "company_intelligence_insight_source_key")
  @@index([signalItemId], map: "company_intelligence_insight_source_signal_idx")
  @@map("company_intelligence_insight_source")
}

model CompanyInsightFeedback {
  id               String                         @id @default(cuid())
  insightId         String                         @map("insight_id")
  insight           CompanyIntelligenceInsight     @relation(fields: [insightId], references: [id], onDelete: Cascade)
  ratingUsefulness  IntelligenceFeedbackUsefulness @map("rating_usefulness")
  ratingAccuracy    IntelligenceFeedbackAccuracy   @map("rating_accuracy")
  feedbackText      String?                        @map("feedback_text") @db.Text
  submittedBy       String                         @map("submitted_by")
  submittedAt       DateTime                       @default(now()) @map("submitted_at")

  @@index([insightId, submittedAt], map: "company_insight_feedback_insight_submitted_idx")
  @@index([submittedBy, submittedAt], map: "company_insight_feedback_user_submitted_idx")
  @@map("company_insight_feedback")
}

model CompanyIntelligenceProviderRequestLog {
  id             String                 @id @default(cuid())
  runId          String?                @map("run_id")
  run            CompanyIntelligenceRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  provider       String
  operation      String
  status         String
  requestCount   Int                    @default(1) @map("request_count")
  resultCount    Int?                   @map("result_count")
  durationMs     Int?                   @map("duration_ms")
  model          String?
  costMetadata   Json                   @default("{}") @map("cost_metadata")
  requestMetadata Json                  @default("{}") @map("request_metadata")
  errorMessage   String?                @map("error_message") @db.Text
  createdAt      DateTime               @default(now()) @map("created_at")

  @@index([provider, operation, createdAt], map: "company_intelligence_provider_log_provider_op_idx")
  @@index([runId], map: "company_intelligence_provider_log_run_idx")
  @@map("company_intelligence_provider_request_log")
}

model IntelligenceCalibrationReport {
  id              String   @id @default(cuid())
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  generatedAt     DateTime @default(now()) @map("generated_at")
  generatedBy     String   @map("generated_by")
