# Runtime
NODE_ENV=development

# Optional: only used to call Petyr AI batch endpoints after a full successful sync.
APP_INTERNAL_SECRET=change_me

# PostgreSQL inside root Docker Compose
# Use host "postgres" when running from the repository root docker-compose.yml.
DATABASE_URL=postgresql://unguess:unguess_password@postgres:5432/unguess_redash?schema=public

# Redash
REDASH_BASE_URL=https://data.app-quality.com
REDASH_API_KEY=replace_with_redash_user_or_query_api_key

# header = Authorization: Key <key>
# query  = ?api_key=<key>
REDASH_AUTH_MODE=header

# Redash execution behavior
SYNC_MAX_AGE_SECONDS=0
SYNC_POLL_INTERVAL_MS=2000
SYNC_JOB_TIMEOUT_MS=120000

# Worker schedule and locking
TZ=Europe/Rome
SYNC_DAILY_TIME=01:30
SYNC_LOCK_TTL_SECONDS=3600

# Optional non-secret base path when Redash Ingestor is served through the platform gateway.
# Leave empty for direct local app development; root Docker Compose sets /redash-ingestor.
NEXT_PUBLIC_REDASH_INGESTOR_BASE_PATH=

# Redash Ingestor Access Layer integration.
# Local development defaults to disabled unless explicitly set to access-layer.
# Production must use access-layer and real Coolify secrets.
REDASH_INGESTOR_AUTH_MODE=disabled
ACCESS_LAYER_PUBLIC_BASE_URL=https://access-layer.draftapps.it
ACCESS_LAYER_INTERNAL_BASE_URL=https://access-layer.draftapps.it
ACCESS_LAYER_CALLBACK_URL=https://petyr.draftapps.it/redash-ingestor/auth/callback
ACCESS_LAYER_TOOL_SLUG=redash-ingestor
ACCESS_LAYER_CLIENT_ID=replace_with_redash_ingestor_tool_client_id
ACCESS_LAYER_CLIENT_SECRET=replace_with_redash_ingestor_tool_client_secret
REDASH_INGESTOR_SESSION_SECRET=replace_with_long_random_session_secret

# Optional verbose server-side Petyr/Redash performance instrumentation.
PETYR_PERF_LOGS=false
