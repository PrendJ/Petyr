# UNGUESS Data Platform - local Docker / Coolify environment template

# Runtime
# Coolify production must use production + access-layer. For local unauthenticated development, set NODE_ENV=development and both auth modes to disabled.
NODE_ENV=production

# PostgreSQL shared service inside root docker-compose.yml.
# DATABASE_URL must match POSTGRES_DB, POSTGRES_USER and POSTGRES_PASSWORD.
# If POSTGRES_PASSWORD contains URL-reserved characters, URL-encode it in DATABASE_URL.
POSTGRES_DB=unguess_redash
POSTGRES_USER=unguess
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql://unguess:change_me_postgres_password@postgres:5432/unguess_redash?schema=public

# Public gateway port for local overrides. Root Coolify compose exposes platform-home:8080 without binding a host port.
PLATFORM_HOME_PORT=8080

# Redash
REDASH_BASE_URL=https://data.app-quality.com
REDASH_API_KEY=replace_with_redash_user_or_query_api_key
REDASH_AUTH_MODE=header

# Non-secret route prefix used by the gateway for Redash Ingestor dashboard/API.
# Changing it requires rebuilding the redash-ingestor image.
REDASH_INGESTOR_BASE_PATH=/redash-ingestor

# Internal API protection for admin/recovery endpoints.
APP_INTERNAL_SECRET=replace_with_long_random_internal_secret

# Redash execution behavior
SYNC_MAX_AGE_SECONDS=0
SYNC_POLL_INTERVAL_MS=2000
SYNC_JOB_TIMEOUT_MS=120000

# Optional first-deploy Redash sync. Leave false unless Redash credentials/network should block deploy when sync fails.
REDASH_INITIAL_SYNC_ON_BOOTSTRAP=false

# Worker schedule and locking
TZ=Europe/Rome
SYNC_DAILY_TIME=01:30
SYNC_LOCK_TTL_SECONDS=3600

# Petyr forecasting app
OPENROUTER_API_KEY=replace_with_openrouter_key_or_leave_empty
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
PETYR_DEFAULT_YEAR=current
PETYR_TIMEZONE=Europe/Rome
PETYR_AI_FORECAST_DAILY_TIME=02:00
PETYR_AI_FORECAST_DELAY_MS=3000

# Petyr Access Layer integration.
# Local unauthenticated development may use disabled. Production must use access-layer.
PETYR_AUTH_MODE=access-layer
PETYR_ACCESS_LAYER_PUBLIC_BASE_URL=https://access-layer.draftapps.it
PETYR_ACCESS_LAYER_INTERNAL_BASE_URL=https://access-layer.draftapps.it
PETYR_ACCESS_LAYER_CALLBACK_URL=https://petyr.draftapps.it/auth/callback
PETYR_ACCESS_LAYER_TOOL_SLUG=petyr
PETYR_ACCESS_LAYER_CLIENT_ID=replace_with_petyr_tool_client_id
PETYR_ACCESS_LAYER_CLIENT_SECRET=replace_with_petyr_tool_client_secret
PETYR_SESSION_SECRET=replace_with_long_random_session_secret

# Optional verbose server-side Petyr/Redash performance instrumentation.
PETYR_PERF_LOGS=false
FORECASTING_APP_INTERNAL_URL=http://forecasting-app:3000

# Petyr AI forecast batch after Redash sync.
# Disabled during the manual company-by-company AI Forecasting MVP.
AI_FORECAST_AFTER_SYNC_ENABLED=false
AI_FORECAST_AFTER_SYNC_BATCH_SIZE=3
AI_FORECAST_AFTER_SYNC_DELAY_MS=1200
AI_FORECAST_AFTER_SYNC_DRY_RUN=false

# Redash Ingestor Access Layer integration.
# Local unauthenticated development may use disabled. Production must use access-layer.
REDASH_INGESTOR_AUTH_MODE=access-layer
REDASH_INGESTOR_ACCESS_LAYER_PUBLIC_BASE_URL=https://access-layer.draftapps.it
REDASH_INGESTOR_ACCESS_LAYER_INTERNAL_BASE_URL=https://access-layer.draftapps.it
REDASH_INGESTOR_ACCESS_LAYER_CALLBACK_URL=https://petyr.draftapps.it/redash-ingestor/auth/callback
REDASH_INGESTOR_ACCESS_LAYER_TOOL_SLUG=redash-ingestor
REDASH_INGESTOR_ACCESS_LAYER_CLIENT_ID=replace_with_redash_ingestor_tool_client_id
REDASH_INGESTOR_ACCESS_LAYER_CLIENT_SECRET=replace_with_redash_ingestor_tool_client_secret
REDASH_INGESTOR_SESSION_SECRET=replace_with_long_random_redash_ingestor_session_secret
