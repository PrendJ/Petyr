# Access Control Platform example environment

# Google / OAuth2 Proxy
OAUTH2_PROXY_PROVIDER=google
OAUTH2_PROXY_CLIENT_ID=replace-me
OAUTH2_PROXY_CLIENT_SECRET=replace-me
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-secret
OAUTH2_PROXY_EMAIL_DOMAINS=unguess.io
OAUTH2_PROXY_SET_XAUTHREQUEST=true
OAUTH2_PROXY_PASS_USER_HEADERS=true
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_COOKIE_HTTPONLY=true
OAUTH2_PROXY_COOKIE_SAMESITE=lax

# Auth API
AUTH_API_PORT=4000
AUTH_API_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/unguess_data_platform
AUTH_API_SECRET=replace-with-server-to-server-secret
AUTH_ALLOWED_EMAIL_DOMAIN=unguess.io

# Protected tool integration
TOOL_KEY=petyr_forecasting
AUTH_API_URL=http://auth-api:4000
TRUSTED_AUTH_EMAIL_HEADER=x-auth-request-email
